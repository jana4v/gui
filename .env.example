# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
NUXT_PUBLIC_BASE_URL=http://localhost:3000

# ── API URL Configuration ─────────────────────────────────────────────────────
# All paths are relative by default so they resolve through the current origin
# (nginx in production, Nuxt devProxy in development).
# Set absolute URLs only if your backend is on a different host/port.

# Go gateway API  (proxied by nginx → backend port 21000)
NUXT_PUBLIC_API_BASE=/api/go/v1

# IAM service API  (proxied by nginx → backend port 21005)
NUXT_PUBLIC_IAM_BASE=/iam/api/v1

# Legacy REST API  (proxied by nginx → backend port 21000)
NUXT_PUBLIC_REST_API_BASE=/restApi

# TM chain simulator API  (proxied by nginx → simulator backend)
NUXT_PUBLIC_SIMULATOR_API_BASE=/simulator/api/go/v1

# ── Example overrides for development against a remote server ─────────────────
# NUXT_PUBLIC_API_BASE=http://192.168.1.100/api/go/v1
# NUXT_PUBLIC_IAM_BASE=http://192.168.1.100/iam/api/v1
